{
  "name": "watsonsec",
  "displayName": "WatsonSec",
  "description": "Local-first security engine: runs real scanners (Semgrep, Gitleaks, Trivy, Checkov, Bandit, gosec, Grype, TruffleHog, CodeQL) on every save, deduplicates findings, and surfaces them in a dashboard and MCP bridge.",
  "version": "0.4.0",
  "publisher": "tejgokani",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "security",
    "semgrep",
    "gitleaks",
    "sast",
    "secrets"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tejgokani/watsonsec.git"
  },
  "license": "MIT",
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "watsonsec.runScan",
        "title": "WatsonSec: Run Fast Scan"
      },
      {
        "command": "watsonsec.runFullScan",
        "title": "WatsonSec: Run Full Scan (includes CodeQL)"
      },
      {
        "command": "watsonsec.openDashboard",
        "title": "WatsonSec: Open Dashboard"
      },
      {
        "command": "watsonsec.exportReport",
        "title": "WatsonSec: Export Markdown Report"
      },
      {
        "command": "watsonsec.generateSbom",
        "title": "WatsonSec: Generate SBOM (Syft)"
      }
    ],
    "configuration": {
      "title": "WatsonSec",
      "properties": {
        "watsonsec.semgrepPath": {
          "type": "string",
          "default": "semgrep",
          "description": "Path to the semgrep binary."
        },
        "watsonsec.gitleaksPath": {
          "type": "string",
          "default": "gitleaks",
          "description": "Path to the gitleaks binary."
        },
        "watsonsec.osvScannerPath": {
          "type": "string",
          "default": "osv-scanner",
          "description": "Path to the osv-scanner binary."
        },
        "watsonsec.trivyPath": {
          "type": "string",
          "default": "trivy",
          "description": "Path to the trivy binary."
        },
        "watsonsec.checkovPath": {
          "type": "string",
          "default": "checkov",
          "description": "Path to the checkov binary."
        },
        "watsonsec.banditPath": {
          "type": "string",
          "default": "bandit",
          "description": "Path to the bandit binary."
        },
        "watsonsec.gosecPath": {
          "type": "string",
          "default": "gosec",
          "description": "Path to the gosec binary."
        },
        "watsonsec.grypeePath": {
          "type": "string",
          "default": "grype",
          "description": "Path to the grype binary."
        },
        "watsonsec.trufflehogPath": {
          "type": "string",
          "default": "trufflehog",
          "description": "Path to the trufflehog binary (AGPL-3.0)."
        },
        "watsonsec.codeqlPath": {
          "type": "string",
          "default": "codeql",
          "description": "Path to the codeql binary. Only used during full scans."
        },
        "watsonsec.dashboardPort": {
          "type": "number",
          "default": 7891,
          "description": "Local port for the findings dashboard."
        },
        "watsonsec.debounceMs": {
          "type": "number",
          "default": 2000,
          "description": "Milliseconds to wait after a save before triggering a scan."
        },
        "watsonsec.slowScanSaveInterval": {
          "type": "number",
          "default": 15,
          "description": "Number of fast scans between full scans (which include CodeQL). Set to 0 to disable automatic full scans."
        },
        "watsonsec.syftPath": {
          "type": "string",
          "default": "syft",
          "description": "Path to the syft binary (used for SBOM generation)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build": "npm run bundle",
    "watch": "npm run bundle -- --watch",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.9.3"
  }
}
