{
  "name": "watsonsec",
  "displayName": "WatsonSec",
  "description": "Real-time AI-powered security scanning using Claude",
  "version": "0.1.0",
  "publisher": "watsonsec",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModels": [],
    "commands": [
      {
        "command": "watsonSec.openReport",
        "title": "Open Security Report",
        "category": "WatsonSec"
      },
      {
        "command": "watsonSec.scanAll",
        "title": "Run Full Scan",
        "category": "WatsonSec"
      },
      {
        "command": "watsonSec.scanFile",
        "title": "Scan Current File",
        "category": "WatsonSec"
      },
      {
        "command": "watsonSec.clearResolved",
        "title": "Clear Resolved Findings",
        "category": "WatsonSec"
      },
      {
        "command": "watsonSec.enable",
        "title": "Enable WatsonSec",
        "category": "WatsonSec"
      },
      {
        "command": "watsonSec.disable",
        "title": "Disable WatsonSec",
        "category": "WatsonSec"
      }
    ],
    "configuration": {
      "title": "WatsonSec",
      "properties": {
        "watsonSec.enabled": {
          "type": "boolean",
          "default": true
        },
        "watsonSec.scanOnSave": {
          "type": "boolean",
          "default": true
        },
        "watsonSec.scanOnOpen": {
          "type": "boolean",
          "default": true
        },
        "watsonSec.minSeverity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info"
          ],
          "default": "low"
        },
        "watsonSec.reportPath": {
          "type": "string",
          "default": "security-report.md",
          "description": "Path relative to workspace root"
        },
        "watsonSec.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "How often (in seconds) to re-scan files with active findings to detect resolutions. Set to 0 to disable."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "vsce-package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
